<!-- LANDING PAGE JAVASCRIPT -->
<script>
(function () {

/* ---- 1. AI TYPING DEMO ---- */
var panel   = document.getElementById('lp-code-panel');
var cursor  = document.getElementById('lp-cursor');
var anaBar  = document.getElementById('lp-analysis-bar');
var results = document.getElementById('lp-ai-results');
var items   = results ? results.querySelectorAll('.lp-result-item') : [];

var plainLines = [
    'function getUser(id) {',
    '  if (id = null) {',
    '    return false',
    '  }',
    '  return db.find(id)',
    '}'
];

var colorLines = [
    '<span class="lp-kw">function</span> <span class="lp-fn">getUser</span>(<span class="lp-param">id</span>) {',
    '  <span class="lp-kw">if</span> (<span class="lp-param">id</span> <span class="lp-op">=</span> <span class="lp-kw">null</span>) {',
    '    <span class="lp-kw">return</span> <span class="lp-num">false</span>',
    '  }',
    '  <span class="lp-kw">return</span> <span class="lp-fn">db</span>.<span class="lp-fn">find</span>(<span class="lp-param">id</span>)',
    '}'
];

var lineEls = [];

function typeLine(idx, done) {
    if (idx >= plainLines.length) { done && done(); return; }
    var el = document.createElement('div');
    el.style.minHeight = '1.75em';
    panel.insertBefore(el, cursor);
    lineEls.push(el);
    var plain = plainLines[idx];
    var ci = 0;
    var iv = setInterval(function () {
        ci++;
        el.textContent = plain.slice(0, ci);
        if (ci >= plain.length) {
            clearInterval(iv);
            el.innerHTML = colorLines[idx];
            setTimeout(function () { typeLine(idx + 1, done); }, 60);
        }
    }, 28 + Math.random() * 18);
}

function showResults() {
    anaBar.style.display = 'none';
    results.style.display = 'flex';
    items.forEach(function (item, i) {
        setTimeout(function () {
            item.style.transition = 'opacity .4s ease, transform .4s ease';
            item.style.transform  = 'translateY(10px)';
            item.style.opacity    = '0';
            requestAnimationFrame(function () {
                requestAnimationFrame(function () {
                    item.style.opacity   = '1';
                    item.style.transform = 'translateY(0)';
                });
            });
        }, i * 200);
    });
}

function runDemo() {
    // reset
    lineEls.forEach(function (el) { el.remove(); });
    lineEls.length = 0;
    cursor.style.display = 'inline';
    anaBar.style.display  = 'none';
    results.style.display = 'none';
    items.forEach(function (item) { item.style.opacity = '0'; item.style.transform = ''; item.style.transition = ''; });

    setTimeout(function () {
        typeLine(0, function () {
            cursor.style.display = 'none';
            setTimeout(function () {
                anaBar.style.display = 'flex';
                setTimeout(function () {
                    showResults();
                    // loop again after 7s pause
                    setTimeout(runDemo, 7000);
                }, 2200);
            }, 500);
        });
    }, 600);
}

if (panel && cursor) runDemo();

/* ---- 2. FEATURE TABS ---- */
document.querySelectorAll('.lp-tab').forEach(function (tab) {
    tab.addEventListener('click', function () {
        document.querySelectorAll('.lp-tab').forEach(function (t) { t.classList.remove('active'); });
        document.querySelectorAll('.lp-tab-panel').forEach(function (p) { p.classList.remove('active'); });
        tab.classList.add('active');
        var panel = document.getElementById('tab-' + tab.dataset.tab);
        if (panel) panel.classList.add('active');
    });
});

/* ---- 3. STAT COUNTERS ---- */
function animateCounter(el) {
    var target = parseInt(el.dataset.target, 10);
    var start  = performance.now();
    var dur    = 1400;
    (function tick(now) {
        var p = Math.min((now - start) / dur, 1);
        var eased = 1 - Math.pow(1 - p, 3);
        el.textContent = Math.floor(eased * target);
        if (p < 1) requestAnimationFrame(tick);
        else el.textContent = target;
    })(start);
}

/* ---- 4. INTERSECTION OBSERVER (scroll reveals, counters) ---- */
var revealObs = new IntersectionObserver(function (entries) {
    entries.forEach(function (e) {
        if (e.isIntersecting) e.target.classList.add('revealed');
    });
}, { threshold: 0.1 });

document.querySelectorAll('.reveal-section').forEach(function (s) { revealObs.observe(s); });

var counterObs = new IntersectionObserver(function (entries) {
    entries.forEach(function (e) {
        if (e.isIntersecting) {
            animateCounter(e.target);
            counterObs.unobserve(e.target);
        }
    });
}, { threshold: 0.6 });

document.querySelectorAll('.lp-stat-num').forEach(function (el) { counterObs.observe(el); });

})();
</script>

