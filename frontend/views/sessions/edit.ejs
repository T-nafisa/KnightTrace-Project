<%- include("../partials/header") %>

<section class="page-title">
    <h1>Edit Session</h1>
    <p>Update title or notes.</p>
</section>

<section class="card">
    <form action="/sessions/<%= item.type === "code-lab" ? "code" : item.type %>/<%= item._id %>/update" method="POST">
        <label>Title</label>
        <input type="text" name="title" value="<%= item.title %>" required>

        <label>Notes</label>
        <textarea name="userNotes" rows="8"><%= item.userNotes || "" %></textarea>

        <button type="submit">Save Changes</button>
    </form>
</section>

<%- include("../partials/footer") %>