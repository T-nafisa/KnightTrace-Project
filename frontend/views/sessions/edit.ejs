<%- include("../partials/header") %>

<section class="page-title">
    <h1>Edit Session</h1>
    <p>Update the title or notes for this saved session.</p>
</section>

<section class="card">
    <form action="/sessions/<%= savedSession._id %>/update" method="POST">
        <label for="title">Title</label>
        <input type="text" name="title" id="title" value="<%= savedSession.title %>" required>

        <label for="userNotes">Notes</label>
        <textarea name="userNotes" id="userNotes" rows="8"><%= savedSession.userNotes || "" %></textarea>

        <button type="submit">Save Changes</button>
    </form>
</section>

<%- include("../partials/footer") %>