<%- include("../partials/header") %>

<section class="page-title">
    <h1>Saved Sessions</h1>
    <p>Your AI Code Lab history is saved here.</p>
</section>

<% if (savedSessions.length === 0) { %>
    <section class="card">
        <p>No saved sessions yet.</p>
        <a class="button secondary" href="/code">Start Code Lab</a>
    </section>
<% } else { %>
    <section class="card-grid">
        <% savedSessions.forEach(function (item) { %>
            <div class="card">
                <h2><%= item.title %></h2>
                <p><%= item.type %> | <%= item.language || item.topic || "General" %></p>
                <p><%= item.createdAt.toDateString() %></p>

                <div class="button-row">
                    <a class="button secondary" href="/sessions/<%= item._id %>">View</a>
                    <a class="button secondary" href="/sessions/<%= item._id %>/edit">Edit</a>

                    <form action="/sessions/<%= item._id %>/delete" method="POST">
                        <button type="submit">Delete</button>
                    </form>
                </div>
            </div>
        <% }) %>
    </section>
<% } %>

<%- include("../partials/footer") %>